{
  "name": "vector-text-extruder-web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "electron/main.mjs",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:web\" \"npm:dev:desktop\"",
    "dev:web": "vite --host 127.0.0.1 --port 5173 --strictPort",
    "dev:desktop": "wait-on tcp:127.0.0.1:5173 && electron . --dev",
    "build": "npm run build:all",
    "build:web": "tsc -b && vite build --outDir \"web app\"",
    "build:web:cpanel": "tsc -b && vite build --base ./ --outDir \"web app\"",
    "pack:windows": "electron-builder --config electron-builder.windows-app.json",
    "pack:itch": "electron-builder --config electron-builder.itch-build.json",
    "build:windows": "npm run build:web && npm run pack:windows",
    "build:itch": "npm run build:web && npm run pack:itch",
    "build:all": "npm run build:web && npm run pack:windows && npm run pack:itch",
    "preview": "vite preview --host 127.0.0.1 --port 4173 --strictPort"
  },
  "dependencies": {
    "@fontsource/space-mono": "^5.2.9",
    "gifenc": "^1.0.3",
    "mime-db": "^1.52.0",
    "opentype.js": "^1.3.5",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "three": "^0.181.1"
  },
  "devDependencies": {
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.181.0",
    "@vitejs/plugin-react": "^5.1.0",
    "concurrently": "^9.2.1",
    "electron": "^41.2.1",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.28.0",
    "lightningcss-win32-x64-msvc": "^1.32.0",
    "png-to-ico": "^3.0.1",
    "sharp": "^0.34.5",
    "typescript": "~6.0.2",
    "vite": "^7.1.12",
    "wait-on": "^9.0.5"
  }
}
